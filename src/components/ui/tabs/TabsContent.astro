---
import type { HTMLAttributes } from 'astro/types'
import type { VariantProps } from 'class-variance-authority'
// Generated from bejamas-juno style registry. Do not edit packages/ui/src/components/tabs/TabsContent.astro directly.
import { cva } from 'class-variance-authority'
import { cn } from '@/lib/utils'

export const tabsContentVariants = cva(
  `
    hidden flex-1 outline-none
    data-[state=active]:block
  `,
  {
    variants: {
      animation: {
        none: '',
        fade: `
          data-[state=active]:animate-in data-[state=active]:duration-200
          data-[state=active]:fade-in-0
        `,
        slide:
          `
            data-[state=active]:animate-in data-[state=active]:duration-200
            data-[state=active]:fade-in-0
            data-[state=active]:slide-in-from-bottom-2
          `,
        direction:
          `
            data-[activation-direction=down]:fade-in-0
            data-[activation-direction=down]:slide-in-from-bottom-2
            data-[activation-direction=left]:fade-in-0
            data-[activation-direction=left]:slide-in-from-left-2
            data-[activation-direction=right]:fade-in-0
            data-[activation-direction=right]:slide-in-from-right-2
            data-[activation-direction=up]:fade-in-0
            data-[activation-direction=up]:slide-in-from-top-2
            data-[state=active]:animate-in data-[state=active]:duration-200
          `,
      },
    },
    defaultVariants: {
      animation: 'none',
    },
  },
)

interface Props extends VariantProps<typeof tabsContentVariants>, HTMLAttributes<'div'> {
  value: string
  class?: string
}

const {
  value,
  animation = 'none',
  class: className = '',
  ...rest
} = Astro.props as Props;
---

<div
  {...rest}
  role="tabpanel"
  data-slot="tabs-content"
  data-value={value}
  tabindex="0"
  class={cn('text-sm', tabsContentVariants({ animation }), className)}
>
  <slot />
</div>

---
import type { HTMLAttributes } from 'astro/types'
import type { VariantProps } from 'class-variance-authority'
// Generated from bejamas-juno style registry. Do not edit packages/ui/src/components/tabs/TabsList.astro directly.
import { cva } from 'class-variance-authority'
import { cn } from '@/lib/utils'

export const tabsListVariants = cva(
  `
    group/tabs-list relative inline-flex w-fit items-center justify-center
    text-muted-foreground
    group-data-[orientation=vertical]/tabs:h-fit
    group-data-[orientation=vertical]/tabs:flex-col
  `,
  {
    variants: {
      variant: {
        'indicator': `
          rounded-lg bg-muted p-[2px]
          [--tabs-indicator-radius:calc(var(--radius)-2px)]
        `,
        'default': 'rounded-lg bg-muted p-[3px]',
        'line': 'gap-1 rounded-none bg-transparent p-0',
        'line-animated':
          'gap-1 rounded-none bg-transparent p-0',
      },
      size: {
        default: 'group-data-horizontal/tabs:h-9',
        sm: 'group-data-horizontal/tabs:h-8',
        lg: 'group-data-horizontal/tabs:h-10',
      },
    },
    defaultVariants: {
      variant: 'indicator',
      size: 'default',
    },
  },
)

interface Props
  extends VariantProps<typeof tabsListVariants>, HTMLAttributes<'div'> {
  class?: string
}

const {
  variant = 'indicator',
  size = 'default',
  class: className = '',
  ...rest
} = Astro.props as Props;
---

<div
  {...rest}
  role="tablist"
  data-slot="tabs-list"
  data-variant={variant}
  class={cn('', tabsListVariants({ variant, size }), className)}
>
  {
    variant === 'indicator' && (
      <div
        aria-hidden="true"
        data-slot="tabs-indicator"
        class="
          ease pointer-events-none absolute top-(--active-tab-top)
          left-(--active-tab-left) z-0 h-(--active-tab-height)
          w-(--active-tab-width) gap-1.5 rounded-md border border-transparent
          bg-background px-2 py-1 text-sm font-medium shadow-sm transition-all
          duration-150
          dark:border-input dark:bg-input/30
          group-data-[variant=default]/tabs-list:data-active:shadow-sm
          group-data-[variant=line]/tabs-list:data-active:shadow-none
          [&_svg:not([class*='size-'])]:size-4
        "
      />
    )
  }
  {
    variant === 'line-animated' && (
      <div
        aria-hidden="true"
        data-slot="tabs-indicator"
        class="
          ease pointer-events-none absolute z-0 rounded-full bg-foreground
          transition-all duration-150
          group-data-[orientation=horizontal]/tabs:top-[calc(var(--active-tab-top)+var(--active-tab-height)-2px)]
          group-data-[orientation=horizontal]/tabs:left-(--active-tab-left)
          group-data-[orientation=horizontal]/tabs:h-0.5
          group-data-[orientation=horizontal]/tabs:w-(--active-tab-width)
          group-data-[orientation=vertical]/tabs:top-(--active-tab-top)
          group-data-[orientation=vertical]/tabs:left-[calc(var(--active-tab-left)+var(--active-tab-width)-2px)]
          group-data-[orientation=vertical]/tabs:h-(--active-tab-height)
          group-data-[orientation=vertical]/tabs:w-0.5
        "
      />
    )
  }
  <slot />
</div>

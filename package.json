{
  "name": "shako",
  "type": "module",
  "version": "0.7.1",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "docs:dev": "zensical serve",
    "docs:build": "zensical build",
    "docker:build": "docker buildx build -f docker/Dockerfile -t ghcr.io/keksiqc/shako:latest .",
    "docker:start": "docker run -p 3000:3000 ghcr.io/keksiqc/shako:latest",
    "up": "taze major -I -l",
    "bump": "bumpp",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/react": "5.0.3",
    "@data-slot/tabs": "^0.2.166",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@iconify-json/lucide": "^1.2.101",
    "@iconify-json/simple-icons": "^1.2.77",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "6.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "use-lanyard": "^1.7.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.1.1",
    "@astrojs/check": "0.9.8",
    "@astrojs/ts-plugin": "1.10.7",
    "@eslint-react/eslint-plugin": "3.0.0",
    "@playform/compress": "0.2.3",
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro-eslint-parser": "1.4.0",
    "astro-icon": "1.1.5",
    "bumpp": "11.0.1",
    "c12": "4.0.0-beta.4",
    "eslint": "10.2.0",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-better-tailwindcss": "4.3.2",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "simple-git-hooks": "2.13.1",
    "taze": "19.11.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
